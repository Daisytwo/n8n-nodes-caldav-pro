{
  "name": "n8n-nodes-caldav-pro",
  "version": "2.3.3",
  "description": "n8n community node for CalDAV calendars (Infomaniak, NextCloud, iCloud, Fastmail). Usable as AI Agent tool.",
  "keywords": [
    "n8n-community-node-package",
    "n8n",
    "caldav",
    "calendar",
    "infomaniak",
    "nextcloud",
    "icloud",
    "ical",
    "ai-agent"
  ],
  "license": "MIT",
  "homepage": "https://github.com/Daisytwo/n8n-nodes-caldav-pro",
  "author": {
    "name": "Daisytwo"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Daisytwo/n8n-nodes-caldav-pro.git"
  },
  "main": "index.js",
  "scripts": {
    "build": "tsc && gulp build:icons",
    "dev": "tsc --watch",
    "format": "prettier nodes credentials --write",
    "lint": "eslint nodes credentials package.json",
    "lintfix": "eslint nodes credentials package.json --fix",
    "prepublishOnly": "npm run build && npm run lint"
  },
  "files": [
    "dist"
  ],
  "n8n": {
    "n8nNodesApiVersion": 1,
    "credentials": [
      "dist/credentials/CalDavApi.credentials.js"
    ],
    "nodes": [
      "dist/nodes/CalDav/CalDav.node.js"
    ]
  },
  "dependencies": {
    "fast-xml-parser": "^4.5.0",
    "ical.js": "^2.1.0"
  },
  "peerDependencies": {
    "n8n-workflow": "*"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@typescript-eslint/parser": "^7.15.0",
    "eslint": "^8.56.0",
    "eslint-plugin-n8n-nodes-base": "^1.16.1",
    "gulp": "^4.0.2",
    "jsonc-eslint-parser": "^3.1.0",
    "n8n-workflow": "*",
    "prettier": "^3.3.2",
    "typescript": "^5.5.3"
  }
}
